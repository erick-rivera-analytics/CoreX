      <bpmndi:BPMNEdge id="Edge_Flow_Apertura_Directo_Clasificado_B2A_Blanco" bpmnElement="Flow_Apertura_Directo_Clasificado_B2A_Blanco"><di:waypoint x="1375" y="1165" /><di:waypoint x="1415" y="1165" /></bpmndi:BPMNEdge>

      <!-- L4 B2A ГўвЂ вЂ™ General (convergence) -->
      <bpmndi:BPMNEdge id="Edge_Flow_Apertura_Directo_B2A_General_Arcoiris" bpmnElement="Flow_Apertura_Directo_B2A_General_Arcoiris"><di:waypoint x="1525" y="1015" /><di:waypoint x="1545" y="1015" /><di:waypoint x="1545" y="1090" /><di:waypoint x="1565" y="1090" /></bpmndi:BPMNEdge>
