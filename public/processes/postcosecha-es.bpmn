      <bpmndi:BPMNEdge id="Edge_Flow_Apertura_Directo_B2A_General_Blanco" bpmnElement="Flow_Apertura_Directo_B2A_General_Blanco"><di:waypoint x="1525" y="1165" /><di:waypoint x="1545" y="1165" /><di:waypoint x="1545" y="1090" /><di:waypoint x="1565" y="1090" /></bpmndi:BPMNEdge>

      <!-- Convergence: General ГўвЂ вЂ™ Cierre_Superior (L1+L2) / Cierre_Inferior (L3+L4) -->
      <bpmndi:BPMNEdge id="Edge_Flow_Pre_GV_Cierre" bpmnElement="Flow_Pre_GV_Cierre"><di:waypoint x="1675" y="190" /><di:waypoint x="1753" y="190" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Pre_Directo_Cierre" bpmnElement="Flow_Pre_Directo_Cierre"><di:waypoint x="1675" y="490" /><di:waypoint x="1715" y="490" /><di:waypoint x="1715" y="190" /><di:waypoint x="1753" y="190" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Apertura_GV_Cierre" bpmnElement="Flow_Apertura_GV_Cierre"><di:waypoint x="1675" y="790" /><di:waypoint x="1753" y="790" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Apertura_Directo_Cierre" bpmnElement="Flow_Apertura_Directo_Cierre"><di:waypoint x="1675" y="1090" /><di:waypoint x="1715" y="1090" /><di:waypoint x="1715" y="790" /><di:waypoint x="1753" y="790" /></bpmndi:BPMNEdge>

      <!-- Final merge ГўвЂ вЂ™ EndEvent -->
      <bpmndi:BPMNEdge id="Edge_Flow_Cierre_Superior_Final" bpmnElement="Flow_Cierre_Superior_Final"><di:waypoint x="1803" y="190" /><di:waypoint x="1852" y="190" /><di:waypoint x="1852" y="490" /><di:waypoint x="1875" y="490" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Cierre_Inferior_Final" bpmnElement="Flow_Cierre_Inferior_Final"><di:waypoint x="1803" y="790" /><di:waypoint x="1852" y="790" /><di:waypoint x="1852" y="490" /><di:waypoint x="1875" y="490" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Final_End" bpmnElement="Flow_Final_End"><di:waypoint x="1925" y="490" /><di:waypoint x="1960" y="490" /></bpmndi:BPMNEdge>

