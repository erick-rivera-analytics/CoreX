# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.next-start.log
.*.log

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.production.example

# virtual environments and local diagnostics
/venv/
react-doctor-report.txt

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# GIS raw files (large drone rasters – not for VCS)
/Capas/*.tif
/Capas/*.ovr
/Capas/*.tfw
/Capas/*.sbn
/Capas/*.sbx
# Note: public/rasters/*.png are committed (generated, ~0.5 MB each)

# Project vault (local docs)
project_vault/
.kilocode/

canon_capas_v2/
capas_v2/
*.tif
*.ovr
